# Flask 環境設定 (觸發本機模式)
FLASK_ENV=development
APP_ENV=development

# 應用程式安全金鑰 (本機測試隨便填，正式環境會使用 Docker Secrets)
SECRET_KEY=dev_local_secret_key_12345

# Redis 連線 (如果您本地有起 Redis)
REDIS_URL=redis://127.0.0.1:6379/0

# CORS 設定 (本地開發預設配置)
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# Cloudflare Turnstile (本地測試可留空或填寫測試金鑰)
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# 其他選填參數
# SHARE_TTL=7200
