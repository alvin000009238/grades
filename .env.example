## necessary
SECRET_KEY=

## NOT necessary
TUNNEL_TOKEN=
CORS_ORIGINS=
REDIS_URL=redis://redis:6379/0

## HTTP Client Settings (Optional)
HTTP_RETRY_TOTAL=3
HTTP_TIMEOUT_CONNECT=5.0
HTTP_TIMEOUT_READ=20.0
HTTP_BACKOFF_FACTOR=0.5

## Cloudflare Turnstile (測試用 key)
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

## Share Settings (預設 7200 秒，即 2 小時)
SHARE_TTL=7200
